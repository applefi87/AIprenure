# .env.example — copy to .env and fill in real values. DO NOT commit .env.

# ── Gemini API (Reasoning agents: Spec, Review) ──────────────────────────────
# Free tier, no credit card needed.
# Get key at: https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=AIza...

# ── Claude Code (Coding agents: Test, Code) ──────────────────────────────────
# Uses your Claude Pro subscription — no API key needed here.
# One-time setup: npm install -g @anthropic-ai/claude-code && claude login
# (login uses your claude.ai account, not an API key)

# ── Anthropic API (Optional — only if you switch reasoning_provider to "claude") ──
# Requires paid API account at console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram (M5 only) ───────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ── GitHub (M3 only) ─────────────────────────────────────────────────────────
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=your-org/your-repo
